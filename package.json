{
  "name": "metflix",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @metflix/api run start:dev",
    "dev:web": "npm --workspace @metflix/web run dev",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace @metflix/api run build",
    "build:web": "npm --workspace @metflix/web run build",
    "db:seed": "npm --workspace @metflix/api run db:seed",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
