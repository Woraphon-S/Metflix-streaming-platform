# =============================================================================
# METFLIX — environment template
# Copy to .env and adjust:  cp .env.example .env   (Windows: copy .env.example .env)
# Defaults below work out-of-the-box with `docker compose up -d --build`.
# =============================================================================

# ----- Database (Postgres) -----
POSTGRES_USER=metflix
POSTGRES_PASSWORD=metflix
POSTGRES_DB=metflix
POSTGRES_PORT=5432

# Connection string used by the API when running OUTSIDE Docker (local dev).
# Host is "localhost" here for local dev. Inside docker-compose the API ignores
# this and connects to the "postgres" service automatically.
DATABASE_URL=postgresql://metflix:metflix@localhost:5432/metflix

# ----- API (NestJS) -----
API_PORT=4000
NODE_ENV=development

# Signs/verifies JWTs. Generate a long random string, e.g. `openssl rand -hex 32`.
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed browser origins.
CORS_ORIGIN=http://localhost:3000

# Fixed dev admin per project spec — DEMO ONLY, do not deploy as-is.
ADMIN_DEV_ID=admin
ADMIN_DEV_PASSWORD=1234

# ----- Web (Next.js) -----
WEB_PORT=3000

# URL the browser uses to call the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
